{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "TronRental API",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
